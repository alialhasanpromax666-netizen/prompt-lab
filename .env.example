# قاعدة بيانات PostgreSQL (Neon, Supabase, إلخ)
# للتطوير المحلي: DATABASE_URL="file:./dev.db"
DATABASE_URL="postgresql://user:password@host:5432/neondb?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="ضع-قيمة-عشوائية-هنا"
AUTH_SECRET="ضع-قيمة-عشوائية-هنا"

# مفتاح TokenRouter (مطلوب لتوليد البرومتات)
# سجّل واحصل على مفتاح مجاني: https://tokenrouter.com
TOKENROUTER_API_KEY="sk-your-key-here"

# Google OAuth (اختياري — لتسجيل الدخول عبر Google)
# AUTH_GOOGLE_ID="your-google-client-id"
# AUTH_GOOGLE_SECRET="your-google-client-secret"
